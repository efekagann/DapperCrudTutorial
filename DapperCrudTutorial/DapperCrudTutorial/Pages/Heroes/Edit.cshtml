@page "{id:int}"
@model DapperCrudTutorial.Pages.Heroes.EditModel
@{
    ViewData["Title"] = "Kahramanı Düzenle";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Kahramanı Düzenle</h4>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <input type="hidden" asp-for="Hero.Id" />

                    <div class="mb-3">
                        <label asp-for="Hero.Name" class="form-label"></label>
                        <input asp-for="Hero.Name" class="form-control" />
                        <span asp-validation-for="Hero.Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Hero.FirstName" class="form-label"></label>
                        <input asp-for="Hero.FirstName" class="form-control" />
                        <span asp-validation-for="Hero.FirstName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Hero.LastName" class="form-label"></label>
                        <input asp-for="Hero.LastName" class="form-control" />
                        <span asp-validation-for="Hero.LastName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Hero.Place" class="form-label"></label>
                        <input asp-for="Hero.Place" class="form-control" />
                        <span asp-validation-for="Hero.Place" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Güncelle</button>
                        <a asp-page="Index" class="btn btn-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
