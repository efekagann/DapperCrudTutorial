@page
@model DapperCrudTutorial.Pages.Heroes.CreateModel
@{
    ViewData["Title"] = "Yeni Kahraman";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">Yeni Kahraman Ekle</h4>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Hero.Name" class="form-label"></label>
                        <input asp-for="Hero.Name" class="form-control" placeholder="Örn: Spider-Man" />
                        <span asp-validation-for="Hero.Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Hero.FirstName" class="form-label"></label>
                        <input asp-for="Hero.FirstName" class="form-control" placeholder="Örn: Peter" />
                        <span asp-validation-for="Hero.FirstName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Hero.LastName" class="form-label"></label>
                        <input asp-for="Hero.LastName" class="form-control" placeholder="Örn: Parker" />
                        <span asp-validation-for="Hero.LastName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Hero.Place" class="form-label"></label>
                        <input asp-for="Hero.Place" class="form-control" placeholder="Örn: New York" />
                        <span asp-validation-for="Hero.Place" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">Kaydet</button>
                        <a asp-page="Index" class="btn btn-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
